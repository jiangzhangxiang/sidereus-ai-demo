# Demo项目部署敏感配置文件
# ========================================
# 使用说明:
#   1. 复制此文件为 .secrets.env: cp .secrets.env.example .secrets.env
#   2. 修改以下配置值为实际值
#   3. 确保 .secrets.env 已添加到 .gitignore（重要！）
#   4. 执行部署时脚本会自动加载此文件
#
# 安全提醒:
#   - 绝对不要将包含真实密码的此文件提交到版本控制系统
#   - 生产环境建议使用 HashiCorp Vault 或 Docker Secrets 管理敏感信息
#   - 定期轮换数据库密码
# ========================================

# 服务器配置
SERVER_IP=115.29.195.88

# 数据库配置
DB_USERNAME=demo
DB_PASSWORD=demo_prod_2026
DB_DATABASE=demo

# 服务端口配置 (可选，有默认值)
BACKEND_PORT=3000
FRONTEND_PORT=80

# 钉钉通知配置 (可选)
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
