{
  "name": "demo",
  "version": "1.0.0",
  "description": "全栈 Monorepo 项目",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "dev:build": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build",    
    "dev:stop": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "dev:logs": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml logs -f",
    "dev:ps": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml ps",
    "prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
    "prod:build": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "prod:deploy": "scp -r ./apps deploy.sh docker-compose*.yml ${SERVER_IP}:/opt/demo && ssh ${SERVER_IP} 'cd /opt/demo && docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build'",
    "prod:stop": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml down",
    "prod:logs": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml logs -f",
    "prod:ps": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml ps",
    "db:sync": "docker exec -i demo-postgres psql -U demo -d demo < database/schema.sql",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/core": "^11.1.18",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vite": "^5.4.11"
  }
}