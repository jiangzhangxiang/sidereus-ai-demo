# ============================================
# 后端生产环境配置模板
# ============================================
# 复制此文件为 .env.local 并填入实际值
# 注意：此文件包含敏感信息，请勿提交到 Git！

# 应用配置
NODE_ENV=production
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=demo
DB_PASSWORD=YOUR_STRONG_PASSWORD_HERE
DB_DATABASE=demo

# CORS 配置（允许的前端域名）
CORS_ORIGIN=https://yourdomain.com

# 文件上传配置（可选）
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
