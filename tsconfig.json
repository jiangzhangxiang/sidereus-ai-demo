{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "lib": ["ES2022"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@/*": ["./packages/shared/src/*"],
      "@apps/*": ["./apps/*/src"]
    },
    "types": ["node", "jest"]
  },
  "include": [
    ".trae/**/*.ts",
    "packages/**/*.ts",
    "apps/backend/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/*.tsx",
    "**/*.jsx",
    "apps/frontend/**",
    "apps/*/node_modules/**",
    "apps/*/dist/**"
  ]
}